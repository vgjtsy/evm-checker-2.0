# EVM CHECKER CONFIGURATION

# Основные настройки (по умолчанию)
# DEFAULT_NETWORK=arbitrum
BATCH_SIZE=200
RETRY_ATTEMPTS=3
RETRY_DELAY=1000

# Файловые пути
WALLETS_FILE=wallets.txt
RESULTS_DIR=results

# Логирование
ENABLE_LOGGING=true

# UI настройки
ENABLE_PROGRESS_BAR=true

# Кастомные RPC ссылки
# Чтобы переопределить RPC для сети, используйте формат RPC_URL_[СЕТЬ]="url"
# Примеры:
# RPC_URL_ARBITRUM="https://arb1.arbitrum.io/rpc"
# RPC_URL_OPTIMISM="https://mainnet.optimism.io"
# RPC_URL_BASE="https://mainnet.base.org"
# RPC_URL_POLYGON="https://polygon-rpc.com"
